---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { sbSelect, supaConfigured } from '../lib/supabase';
import { readSession } from '../lib/session';
import { fmtCuit } from '../lib/cuit';
import { DEMO_CLIENTS } from '../lib/demo';

// Mismo gate que el catálogo: acá no se llega sin cuenta habilitada.
const sessionId = readSession(Astro.cookies.get('teia_sess')?.value);
if (!sessionId) return Astro.redirect('/');

const configured = supaConfigured();
const rows = configured
  ? await sbSelect(`teia_clients?id=eq.${sessionId}&select=id,business_name,cuit,client_contact,delivery_address,active`)
  : DEMO_CLIENTS.filter((c) => c.id === sessionId);
const client: any = (rows as any[])[0];
if (!client || client.active === false) {
  Astro.cookies.delete('teia_sess', { path: '/' });
  return Astro.redirect('/');
}
---
<Base title="Confirmá tu pedido — Teia Bakery">
  <header class="top">
    <div class="container top__in">
      <span class="brand">Mayorista<b>Teia Bakery</b></span>
      <a class="admin-link" href="/catalogo">← Volver al catálogo</a>
    </div>
  </header>

  <main class="checkout" id="root">
    <div id="empty" class="empty-state card" hidden>
      <div class="empty-state__icon" aria-hidden="true">🧁</div>
      <p class="empty-state__t">Tu pedido está vacío</p>
      <p class="empty-state__s">Sumá productos al carrito y volvé para confirmar.</p>
      <a class="btn" href="/catalogo">Ir al catálogo</a>
    </div>

    <div id="coGrid" hidden>
      <h1 class="co-title">Confirmá tu pedido</h1>
      <p class="co-sub">Dejanos tus datos. Teia revisa el pedido y te confirma el día de entrega por WhatsApp.</p>

      <div class="co-grid">
        <form id="form" class="card co-form" novalidate>
          <h2>Tus datos</h2>
          <p class="field-hint" style="margin-top:-4px">
            Entraste como <b>{client.business_name}</b> · CUIT {fmtCuit(client.cuit)}
          </p>

          <label for="f-name">Nombre / Comercio</label>
          <input id="f-name" name="client_name" required autocomplete="organization" value={client.business_name || ''} />

          <label for="f-contact">WhatsApp o email</label>
          <input id="f-contact" name="client_contact" required autocomplete="tel" placeholder="Ej: 11 5555-1234" value={client.client_contact || ''} />
          <p class="field-hint">Por acá te confirmamos el pedido y la entrega.</p>

          <label for="f-addr">Dirección de entrega</label>
          <input id="f-addr" name="delivery_address" required autocomplete="street-address" placeholder="Calle, número, localidad" value={client.delivery_address || ''} />

          <label for="f-notes">Aclaraciones (opcional)</label>
          <textarea id="f-notes" name="notes" rows="2" placeholder="Ej: entregar antes de las 10 hs, tocar timbre B…"></textarea>

          <p class="co-note">📅 No hace falta que elijas la fecha: <b>Teia te confirma el día de entrega por WhatsApp.</b></p>
        </form>

        <aside class="co-summary">
          <div class="card co-summary__card">
            <h2>Tu pedido</h2>
            <ul class="order__items co-items" id="cart"></ul>
            <div class="co-total"><span>Total</span><b id="coTotal">$0</b></div>
            <p class="co-trust">🤝 Sin pago online — coordinás el pago con Teia al recibir.</p>
            <button class="btn btn--block" type="submit" form="form" id="submitBtn">Enviar pedido</button>
            <p id="msg" class="co-msg" role="status" aria-live="polite" hidden></p>
          </div>
        </aside>
      </div>
    </div>
  </main>

  <script>
    const money = (n) => '$' + Number(n || 0).toLocaleString('es-AR');
    const esc = (s) => String(s).replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]));
    const el = (id) => document.getElementById(id);
    const sameId = (a, b) => String(a) === String(b);

    // Parse defensivo: un teia_cart corrupto no puede dejar el checkout en blanco para siempre.
    let cart;
    try { const raw = JSON.parse(localStorage.getItem('teia_cart') || '[]'); cart = Array.isArray(raw) ? raw : []; }
    catch { cart = []; }
    const total = () => cart.reduce((s, i) => s + i.price * i.qty, 0);

    // El comercio ya está identificado por la cookie de sesión (entró con su CUIT en la
    // puerta): los datos vienen rellenados desde el servidor, acá solo se pueden ajustar.

    function save() { localStorage.setItem('teia_cart', JSON.stringify(cart)); render(); }
    function change(id, d) {
      const it = cart.find((x) => sameId(x.id, id));
      if (!it) return;
      it.qty += d;
      if (it.qty <= 0) cart = cart.filter((x) => !sameId(x.id, id));
      save();
    }
    function removeItem(id) { cart = cart.filter((x) => !sameId(x.id, id)); save(); }

    function render() {
      const empty = el('empty'), grid = el('coGrid');
      if (!cart.length) { empty.hidden = false; grid.hidden = true; return; }
      empty.hidden = true; grid.hidden = false;

      el('cart').innerHTML = cart.map((i) => {
        const id = esc(String(i.id));
        return `<li class="oi">` +
          `<div class="oi__row1"><span class="oi__name">${esc(i.name)}</span>` +
          `<button class="oi__rm" type="button" data-rm="${id}" aria-label="Quitar ${esc(i.name)}">×</button></div>` +
          `<div class="oi__row2">` +
          `<span class="oi__stepper"><button class="oi__step" type="button" data-dec="${id}" aria-label="Restar uno">−</button>` +
          `<span class="oi__qv">${i.qty}</span>` +
          `<button class="oi__step" type="button" data-inc="${id}" aria-label="Sumar uno">+</button></span>` +
          (i.pack ? `<span class="oi__pack">${esc(i.pack)}</span>` : '') +
          `<span class="oi__line">${money(i.price * i.qty)}</span></div></li>`;
      }).join('');

      el('cart').querySelectorAll('[data-inc]').forEach((b) => (b.onclick = () => change(b.dataset.inc, +1)));
      el('cart').querySelectorAll('[data-dec]').forEach((b) => (b.onclick = () => change(b.dataset.dec, -1)));
      el('cart').querySelectorAll('[data-rm]').forEach((b) => (b.onclick = () => removeItem(b.dataset.rm)));

      el('coTotal').textContent = money(total());
      el('submitBtn').textContent = 'Enviar pedido · ' + money(total());
    }

    el('form').addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target;
      const msg = el('msg'), btn = el('submitBtn');
      // validación amable (campos requeridos)
      const missing = ['client_name', 'client_contact', 'delivery_address'].find((n) => !form.elements[n].value.trim());
      if (missing) {
        const field = form.elements[missing];
        field.focus();
        msg.hidden = false; msg.className = 'co-msg err'; msg.textContent = 'Completá tu nombre, contacto y dirección para enviar el pedido.';
        return;
      }
      const fd = Object.fromEntries(new FormData(form).entries());
      msg.hidden = false; msg.className = 'co-msg'; msg.textContent = 'Enviando…';
      btn.disabled = true;
      try {
        const res = await fetch('/api/order', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ ...fd, items: cart }),
        });
        const out = await res.json().catch(() => ({}));
        if (res.ok && out.ok) {
          localStorage.removeItem('teia_cart'); // el "último pedido" ahora vive en la cuenta (server)
          el('root').innerHTML =
            '<div class="success-state card">' +
            '<div class="success-state__check" aria-hidden="true">✓</div>' +
            '<h1>¡Pedido enviado!</h1>' +
            '<p class="success-state__num">Pedido <b>' + esc(out.order_number || '') + '</b>' +
            (out.total ? ' · Total <b>' + money(out.total) + '</b>' : '') + '</p>' +
            '<p class="success-state__s">Teia lo revisa y te confirma el día de entrega por WhatsApp. ¡Gracias!</p>' +
            '<a class="btn" href="/catalogo">Volver al catálogo</a>' +
            '</div>';
          window.scrollTo({ top: 0, behavior: 'smooth' });
        } else {
          msg.className = 'co-msg err';
          msg.textContent = (out && out.error) ? out.error : 'Hubo un problema al enviar. Probá de nuevo.';
          btn.disabled = false;
        }
      } catch {
        msg.className = 'co-msg err';
        msg.textContent = 'No se pudo enviar. Revisá tu conexión y probá de nuevo.';
        btn.disabled = false;
      }
    });

    render();
  </script>
</Base>
