---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { sbSelect, supaConfigured } from '../lib/supabase';
import { DEMO_PRODUCTS, DEMO_LAST_ORDER } from '../lib/demo';

const configured = supaConfigured();
const raw = configured
  ? await sbSelect('teia_products?active=eq.true&order=category.asc,sort_order.asc,name.asc&select=id,name,description,category,image_url,pack_label,price,stock')
  : DEMO_PRODUCTS.filter((p) => p.active);

const MIN_ORDER = 40000; // pedido mínimo (ARS) — TODO: mover a config de la tienda
const money = (n: any) => '$' + Number(n || 0).toLocaleString('es-AR');
const slug = (s: string) =>
  String(s).toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');

// Rubro order comes from teia_categories (gestionadas en /administradora); fallback a los defaults.
const cats = configured
  ? await sbSelect('teia_categories?order=sort_order.asc,name.asc&select=name')
  : [{ name: 'Tortas' }, { name: 'Postres' }, { name: 'Salados' }, { name: 'Panadería' }];
const ORDER = (cats as any[]).map((c) => c.name);
const groups = new Map<string, any[]>();
for (const p of raw as any[]) {
  const c = (p.category || 'Otros').trim() || 'Otros';
  if (!groups.has(c)) groups.set(c, []);
  groups.get(c)!.push({ ...p, hasStock: Number(p.stock) > 0 });
}
const sections = [...groups.keys()]
  .sort((a, b) => {
    const ia = ORDER.indexOf(a), ib = ORDER.indexOf(b);
    return (ia < 0 ? 99 : ia) - (ib < 0 ? 99 : ib) || a.localeCompare(b);
  })
  .map((name) => ({ name, id: slug(name), items: groups.get(name)! }));

// The demo last order feeds the Recompra card when there's no real history yet.
const demoLast = configured ? null : DEMO_LAST_ORDER;
---
<Base title="Catálogo mayorista — Teia Bakery">
  <header class="top">
    <div class="container top__in">
      <span class="brand">Mayorista<b>Teia Bakery</b></span>
      <a class="admin-link" href="/administradora" title="Panel de administración">⚙️ Admin</a>
    </div>
  </header>

  {sections.length > 0 && (
    <nav class="rubros" aria-label="Rubros">
      <div class="rubros__row">
        {sections.map((s) => <a class="chip" href={`#${s.id}`}>{s.name}</a>)}
      </div>
    </nav>
  )}

  <div class="shop">
    <main class="catalog">
      <h1 class="title">Nuestro catálogo</h1>
      <p class="subtitle">Tocá “Agregar” para sumar al pedido. Mirá cada producto tocando la foto.</p>

      <div id="reorderSlot"></div>

      {!configured && <p class="demo-banner">🧪 <b>Modo demo</b> — productos de ejemplo. Conectá Supabase para usar los reales.</p>}

      {sections.map((s) => (
        <section class="section" id={s.id}>
          <h2 class="rubro">{s.name}</h2>
          <div class="rubro__line"></div>
          <ul class="items">
            {s.items.map((p: any) => (
              <li class="item" data-id={p.id} data-name={p.name} data-price={p.price} data-pack={p.pack_label} data-cat={s.name} data-desc={p.description || ''} data-img={p.image_url || ''}>
                <div class="thumb-box" role="button" tabindex="0" title="Ver más">
                  <span class="thumb-ph" aria-hidden="true">{String(p.name).charAt(0)}</span>
                  {p.image_url && <img class="thumb-img" src={p.image_url} alt={p.name} loading="lazy" width="60" height="60" onerror="this.remove()" />}
                </div>
                <div class="item__info">
                  <p class="item__name">{p.name}</p>
                  {p.description && <p class="item__desc">{p.description}</p>}
                  <div class="item__meta"><span class="pack">{p.pack_label}</span><button class="more-link" type="button">ver más</button></div>
                </div>
                <div class="item__buy">
                  <span class="price">{money(p.price)}</span>
                  {p.hasStock
                    ? <div class="buy-ctl" data-stock="1"></div>
                    : <span class="badge-out">Sin stock</span>}
                </div>
              </li>
            ))}
          </ul>
        </section>
      ))}

      {sections.length === 0 && configured && (
        <p class="card">Todavía no hay productos cargados. Cargalos desde <a href="/administradora">la administradora</a>.</p>
      )}
    </main>

    <aside class="order empty" id="order" aria-label="Tu pedido">
      <div class="order__bar" id="orderBar">
        <div class="order__bar-info">
          <span class="order__bar-total" id="barTotal">$0</span>
          <span class="order__bar-sub" id="barSub">0 productos</span>
        </div>
        <button class="order__bar-cta" id="barCta" type="button">Ver pedido ▲</button>
      </div>
      <div class="order__panel" id="orderPanel" data-lenis-prevent>
        <div class="order__handle" aria-hidden="true"></div>
        <h2 class="order__h">Tu pedido</h2>
        <p class="order__empty" id="orderEmpty">Tu pedido está vacío. Sumá productos con “Agregar”.</p>
        <ul class="order__items" id="orderItems"></ul>
        <div class="meter" id="meter" hidden>
          <div class="meter__track"><div class="meter__fill" id="meterFill"></div></div>
          <p class="meter__t" id="meterT"></p>
        </div>
        <div class="order__total" id="orderTotalRow" hidden><span>Total</span><b id="orderTotal">$0</b></div>
        <a class="btn btn--block" id="confirmBtn" href="/pedido" aria-disabled="true">Confirmar pedido</a>
      </div>
    </aside>
    <div class="backdrop" id="backdrop"></div>
  </div>

  <!-- modal de detalle de producto -->
  <div class="pmodal" id="pmodal" hidden>
    <div class="pmodal__backdrop" data-close></div>
    <div class="pmodal__card" role="dialog" aria-modal="true" data-lenis-prevent>
      <button class="pmodal__x" type="button" data-close aria-label="Cerrar">×</button>
      <div class="pmodal__img" id="pm-img"></div>
      <div class="pmodal__body">
        <h3 id="pm-name"></h3>
        <div class="pmodal__meta"><span class="pack" id="pm-pack"></span><span class="price" id="pm-price"></span></div>
        <p id="pm-desc"></p>
        <div id="pm-buy"></div>
      </div>
    </div>
  </div>

  <script define:vars={{ MIN_ORDER, demoLast }}>
    const KEY = 'teia_cart';
    const fmt = (n) => '$' + Number(n || 0).toLocaleString('es-AR');
    const esc = (s) => String(s).replace(/[&<>"']/g, (m) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[m]));
    const sameId = (a, b) => String(a) === String(b);

    let cart = load();
    let modalId = null;
    function load() { try { return JSON.parse(localStorage.getItem(KEY)) || []; } catch { return []; } }
    function persist() { try { localStorage.setItem(KEY, JSON.stringify(cart)); } catch {} }
    function find(id) { return cart.find((x) => sameId(x.id, id)); }
    function total() { return cart.reduce((s, i) => s + i.price * i.qty, 0); }
    function count() { return cart.reduce((s, i) => s + i.qty, 0); }
    function meta(item) { return { id: item.dataset.id, name: item.dataset.name, price: Number(item.dataset.price), pack: item.dataset.pack, cat: item.dataset.cat, desc: item.dataset.desc, img: item.dataset.img }; }

    const el = (id) => document.getElementById(id);
    const order = el('order');
    const orderItems = el('orderItems'), orderEmpty = el('orderEmpty');
    const totalRow = el('orderTotalRow'), totalEl = el('orderTotal');
    const meter = el('meter'), meterFill = el('meterFill'), meterT = el('meterT');
    const confirmBtn = el('confirmBtn');
    const barTotal = el('barTotal'), barSub = el('barSub');
    const bar = el('orderBar'), backdrop = el('backdrop');
    const modal = el('pmodal');

    function changeQty(id, m, delta, itemEl) {
      const it = find(id);
      const next = Math.max(0, (it ? it.qty : 0) + delta);
      if (next === 0) cart = cart.filter((x) => !sameId(x.id, id));
      else if (it) it.qty = next;
      else cart.push({ id: m.id, name: m.name, price: m.price, pack: m.pack, cat: m.cat, qty: next });
      persist();
      syncItem(id);
      renderOrder();
      if (delta > 0 && itemEl) { itemEl.classList.remove('pulse'); void itemEl.offsetWidth; itemEl.classList.add('pulse'); }
    }

    // ---- control de compra: "Agregar" (qty 0) o stepper − qty + (qty ≥ 1) ----
    function buyHTML(q) {
      return q > 0
        ? '<div class="stepper"><button class="step-btn minus" type="button" aria-label="Quitar">−</button><span class="qty">' + q + '</span><button class="step-btn plus" type="button" aria-label="Agregar más">+</button></div>'
        : '<button class="add-btn add-one" type="button">Agregar</button>';
    }
    function wireBuy(box, id, m, itemEl) {
      box.querySelector('.add-one')?.addEventListener('click', () => changeQty(id, m, +1, itemEl));
      box.querySelector('.plus')?.addEventListener('click', () => changeQty(id, m, +1, itemEl));
      box.querySelector('.minus')?.addEventListener('click', () => changeQty(id, m, -1, itemEl));
    }
    function renderBuy(item) {
      const box = item.querySelector('.buy-ctl');
      if (!box) return;
      const id = item.dataset.id, q = (find(id) || {}).qty || 0;
      box.innerHTML = buyHTML(q);
      wireBuy(box, id, meta(item), item);
      item.classList.toggle('in-cart', q > 0);
    }
    function syncItem(id) {
      document.querySelectorAll('.item[data-id="' + CSS.escape(String(id)) + '"]').forEach(renderBuy);
      if (modalId !== null && sameId(modalId, id)) renderModalBuy();
    }
    function syncAll() { document.querySelectorAll('.item[data-id]').forEach(renderBuy); }

    function renderOrder() {
      const t = total(), c = count();
      order.classList.toggle('empty', c === 0);
      orderEmpty.hidden = c > 0;
      orderItems.innerHTML = cart.map((i) => {
        const id = esc(String(i.id));
        return `<li class="oi">` +
          `<div class="oi__row1"><span class="oi__name">${esc(i.name)}</span>` +
          `<button class="oi__rm" type="button" data-rm="${id}" aria-label="Quitar ${esc(i.name)}">×</button></div>` +
          `<div class="oi__row2">` +
          `<span class="oi__stepper"><button class="oi__step" type="button" data-dec="${id}" aria-label="Restar uno">−</button>` +
          `<span class="oi__qv">${i.qty}</span>` +
          `<button class="oi__step" type="button" data-inc="${id}" aria-label="Sumar uno">+</button></span>` +
          (i.pack ? `<span class="oi__pack">${esc(i.pack)}</span>` : '') +
          `<span class="oi__line">${fmt(i.price * i.qty)}</span></div></li>`;
      }).join('');
      orderItems.querySelectorAll('[data-rm]').forEach((b) =>
        b.addEventListener('click', () => {
          const id = b.dataset.rm;
          cart = cart.filter((x) => !sameId(x.id, id));
          persist(); syncItem(id); renderOrder();
        })
      );
      orderItems.querySelectorAll('[data-inc]').forEach((b) =>
        b.addEventListener('click', () => { const it = find(b.dataset.inc); if (it) changeQty(it.id, it, +1); })
      );
      orderItems.querySelectorAll('[data-dec]').forEach((b) =>
        b.addEventListener('click', () => { const it = find(b.dataset.dec); if (it) changeQty(it.id, it, -1); })
      );
      totalRow.hidden = c === 0;
      totalEl.textContent = fmt(t);
      barTotal.textContent = fmt(t);
      barSub.textContent = c === 1 ? '1 producto' : c + ' productos';

      if (c > 0) {
        meter.hidden = false;
        const reached = t >= MIN_ORDER;
        meterFill.style.width = Math.min(100, Math.round((t / MIN_ORDER) * 100)) + '%';
        meterFill.classList.toggle('ok', reached);
        meterT.innerHTML = reached ? '✓ Llegaste al pedido mínimo' : `Te faltan <b>${fmt(MIN_ORDER - t)}</b> para el mínimo`;
        confirmBtn.setAttribute('aria-disabled', reached ? 'false' : 'true');
      } else {
        meter.hidden = true;
        confirmBtn.setAttribute('aria-disabled', 'true');
      }
    }

    // ---- mobile sheet open/close ----
    const openSheet = () => order.classList.add('open');
    const closeSheet = () => order.classList.remove('open');
    bar?.addEventListener('click', () => (order.classList.contains('open') ? closeSheet() : openSheet()));
    backdrop?.addEventListener('click', closeSheet);
    document.querySelector('.order__handle')?.addEventListener('click', closeSheet);
    confirmBtn.addEventListener('click', (e) => { if (confirmBtn.getAttribute('aria-disabled') === 'true') e.preventDefault(); });

    // ---- modal detalle de producto ----
    let lastFocus = null;
    function openModal(item) {
      modalId = item.dataset.id;
      lastFocus = document.activeElement;
      const m = meta(item);
      el('pm-name').textContent = m.name;
      el('pm-pack').textContent = m.pack || '';
      el('pm-price').textContent = fmt(m.price);
      el('pm-desc').textContent = m.desc || 'Sin descripción.';
      el('pm-img').innerHTML = m.img
        ? '<img src="' + esc(m.img) + '" alt="' + esc(m.name) + '">'
        : '<span class="pm-ph">' + esc((m.name.charAt(0) || '?').toUpperCase()) + '</span>';
      renderModalBuy();
      modal.hidden = false;
      modal.querySelector('.pmodal__x')?.focus();
    }
    function closeModal() {
      if (modal.hidden) return;
      const done = () => { modal.hidden = true; modal.classList.remove('closing'); modalId = null; lastFocus?.focus?.(); };
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return done();
      modal.classList.add('closing');
      setTimeout(done, 170);
    }
    function renderModalBuy() {
      const box = el('pm-buy');
      if (!box || modalId === null) return;
      const item = document.querySelector('.item[data-id="' + CSS.escape(String(modalId)) + '"]');
      const inStock = item ? item.querySelector('.buy-ctl') != null : false;
      const q = (find(modalId) || {}).qty || 0;
      box.innerHTML = inStock ? buyHTML(q) : '<span class="badge-out">Sin stock</span>';
      if (item && inStock) wireBuy(box, modalId, meta(item), item);
    }
    modal?.querySelectorAll('[data-close]').forEach((b) => b.addEventListener('click', closeModal));
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && modal && !modal.hidden) closeModal(); });
    document.querySelectorAll('.item[data-id]').forEach((item) => {
      const open = () => openModal(item);
      item.querySelector('.thumb-box')?.addEventListener('click', open);
      item.querySelector('.item__name')?.addEventListener('click', open);
      item.querySelector('.more-link')?.addEventListener('click', open);
    });

    // ---- scroll-spy: resalta el chip del rubro visible al hacer scroll ----
    const chips = document.querySelectorAll('.rubros .chip');
    if (chips.length && 'IntersectionObserver' in window) {
      const chipById = {};
      chips.forEach((c) => { const h = c.getAttribute('href'); if (h) chipById[h.slice(1)] = c; });
      const spy = new IntersectionObserver((entries) => {
        entries.forEach((en) => {
          if (en.isIntersecting) {
            chips.forEach((c) => c.classList.remove('is-active'));
            chipById[en.target.id]?.classList.add('is-active');
          }
        });
      }, { rootMargin: '-45% 0px -50% 0px', threshold: 0 });
      document.querySelectorAll('section.section[id]').forEach((s) => spy.observe(s));
    }

    // ---- Recompra (reorder): localStorage (mismo aparato) + búsqueda por WhatsApp (cross-device) ----
    function lastOrder() {
      try {
        const ls = JSON.parse(localStorage.getItem('teia_last_order'));
        if (ls && Array.isArray(ls.items) && ls.items.length) return ls;
      } catch {}
      return demoLast || null;
    }
    function loadIntoCart(items) {
      items.forEach((i) => {
        const ex = find(i.id);
        if (ex) ex.qty += i.qty;
        else cart.push({ id: i.id, name: i.name, price: i.price, pack: i.pack, qty: i.qty });
      });
      persist(); syncAll(); renderOrder();
      if (window.innerWidth < 900) openSheet();
    }
    function renderReorderCard(lo) {
      const box = el('reorderCard');
      if (!box) return;
      if (!lo || !lo.items || !lo.items.length) { box.innerHTML = ''; return; }
      const c = lo.items.reduce((s, i) => s + i.qty, 0);
      const t = lo.items.reduce((s, i) => s + i.price * i.qty, 0);
      box.innerHTML =
        `<div class="reorder"><div><div class="reorder__t">↻ Repetir último pedido</div>` +
        `<div class="reorder__s">${esc(lo.order_number || '')} · ${c} ítems · ${fmt(t)}</div></div>` +
        `<button class="reorder__btn" type="button" id="reorderBtn">Cargar</button></div>`;
      el('reorderBtn').addEventListener('click', () => loadIntoCart(lo.items));
    }

    el('reorderSlot').innerHTML =
      '<div id="reorderCard"></div>' +
      '<div class="reorder-lookup">' +
        '<button type="button" class="reorder-lookup__toggle" id="rlToggle">↻ Traé tu último pedido con tu WhatsApp</button>' +
        '<form class="reorder-lookup__form" id="rlForm" hidden>' +
          '<input type="tel" id="rlInput" placeholder="Tu WhatsApp (ej: 11 5555-1234)" autocomplete="tel" inputmode="tel" />' +
          '<button type="submit" class="btn" id="rlBtn">Buscar</button>' +
        '</form>' +
        '<p class="reorder-lookup__msg" id="rlMsg" hidden></p>' +
      '</div>';

    renderReorderCard(lastOrder());

    el('rlToggle').addEventListener('click', () => {
      const f = el('rlForm');
      f.hidden = !f.hidden;
      if (!f.hidden) el('rlInput').focus();
    });
    el('rlForm').addEventListener('submit', async (e) => {
      e.preventDefault();
      const contact = el('rlInput').value.trim();
      const msg = el('rlMsg'), btn = el('rlBtn');
      if (!contact) return;
      msg.hidden = true; btn.textContent = 'Buscando…'; btn.disabled = true;
      try {
        const r = await fetch('/api/last-order', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ contact }),
        });
        const o = await r.json().catch(() => ({}));
        if (r.ok && o.ok && o.items && o.items.length) {
          const lo = { order_number: o.order_number || '', items: o.items };
          try { localStorage.setItem('teia_last_order', JSON.stringify(lo)); } catch {}
          renderReorderCard(lo);
          el('rlForm').hidden = true;
          msg.hidden = false; msg.className = 'reorder-lookup__msg ok'; msg.textContent = '✓ ¡Encontramos tu pedido! Tocá “Cargar”.';
        } else {
          msg.hidden = false; msg.className = 'reorder-lookup__msg'; msg.textContent = (o && o.error) || 'No encontramos pedidos con ese contacto.';
        }
      } catch {
        msg.hidden = false; msg.className = 'reorder-lookup__msg'; msg.textContent = 'No se pudo buscar. Probá de nuevo.';
      } finally {
        btn.textContent = 'Buscar'; btn.disabled = false;
      }
    });

    // ---- init ----
    syncAll();
    renderOrder();
  </script>
</Base>
