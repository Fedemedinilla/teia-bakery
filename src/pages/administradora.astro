---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { isTeiaAdmin, authChallenge } from '../lib/auth';
import { sbSelect, supaConfigured } from '../lib/supabase';
import { DEMO_PRODUCTS, DEMO_ORDERS, DEMO_ORDER_ITEMS } from '../lib/demo';

// Gate: in real mode (Supabase configured) require the panel password. In demo mode it's open.
const configured = supaConfigured();
if (configured && !isTeiaAdmin(Astro.request)) {
  return authChallenge();
}

const products = configured ? await sbSelect('teia_products?order=sort_order.asc,name.asc&select=*') : DEMO_PRODUCTS;
const orders = configured ? await sbSelect('teia_orders?order=created_at.desc&select=*&limit=50') : DEMO_ORDERS;

// Ítems de cada pedido (para mostrar QUÉ se pidió + editar cantidades).
const orderIds = (orders as any[]).map((o) => o.id);
const orderItems = configured
  ? (orderIds.length ? await sbSelect(`teia_order_items?order_id=in.(${orderIds.join(',')})&select=*&order=id.asc`) : [])
  : DEMO_ORDER_ITEMS;
const itemsByOrder: Record<string, any[]> = {};
for (const it of orderItems as any[]) { (itemsByOrder[it.order_id] ||= []).push(it); }

// Marca si el pedido ya tiene sus remitos archivados (links vs botón "Reintentar").
const orderRows = (orders as any[]).map((o) => ({ ...o, archived: o.archive_status === 'archivado' && !!o.remito_cliente_url }));

const money = (n: any) => '$' + Number(n || 0).toLocaleString('es-AR');

// Stock flags precomputed (Astro can't mix `<=` with adjacent JSX).
const productRows = (products as any[]).map((p) => ({
  ...p,
  isOut: Number(p.stock) <= 0,
  isLow: Number(p.stock) > 0 && Number(p.stock) <= Number(p.low_stock_threshold),
}));

// Rubros/categorías (gestionables en la pestaña Rubros); fallback a los defaults en demo.
const categories = configured
  ? await sbSelect('teia_categories?order=sort_order.asc,name.asc&select=*')
  : [{ id: 1, name: 'Tortas' }, { id: 2, name: 'Postres' }, { id: 3, name: 'Salados' }, { id: 4, name: 'Panadería' }];
const catNames = (categories as any[]).map((c) => c.name);

const DRIVE_URL = '';
const SHEET_URL = '';
---
<Base title="Administradora — Teia Bakery">
  <div class="container admin-wrap">
    <div class="brand">Teia Bakery · Administradora</div>
    <h1 style="margin-bottom:6px">Panel</h1>

    {!configured && <p class="card" style="margin-bottom:12px">🧪 <b>Modo demo</b> — datos de ejemplo. Conectá Supabase + la clave para el panel real.</p>}

    <p class="links-row">
      <a class="btn" href="/catalogo">🛍️ Ir al catálogo</a>
      <a class="btn btn--ghost" href={DRIVE_URL || '#'} target="_blank" rel="noopener">📁 Drive</a>
      <a class="btn btn--ghost" href={SHEET_URL || '#'} target="_blank" rel="noopener">📊 Google Sheet</a>
      <a class="btn btn--ghost" href="mailto:hello@kyndredai.com">🛟 Soporte</a>
    </p>

    <div class="tabs" role="tablist">
      <button class="tab is-active" data-tab="pedidos" type="button">Pedidos</button>
      <button class="tab" data-tab="productos" type="button">Productos</button>
      <button class="tab" data-tab="nuevo" type="button">＋ Nuevo producto</button>
      <button class="tab" data-tab="rubros" type="button">Rubros</button>
    </div>

    <!-- PEDIDOS -->
    <section class="panel" data-panel="pedidos">
      {orders.length === 0 && <p class="card muted">Sin pedidos todavía.</p>}
      {orderRows.map((o: any) => (
        <div class="card ordcard" data-id={o.id}>
          <div class="ordcard__head">
            <div>
              <span class="ordcard__num">{o.order_number || `#${o.id}`}</span>
              <span class={`badge badge--${o.status === 'confirmado' ? 'ok' : 'wait'}`}>{o.status}</span>
            </div>
            <div class="ordcard__total" data-total>{money(o.total)}</div>
          </div>

          {o.status === 'pendiente' && (
            <label class="ordcard__disc">
              <input type="checkbox" class="disc-toggle" checked={Number(o.discount_pct) === 10} />
              Descuento fiel −10% <span class="ordcard__disc-hint">(clientes fieles)</span>
            </label>
          )}
          {o.status !== 'pendiente' && Number(o.discount_pct) > 0 && (
            <div class="ordcard__disc ordcard__disc--applied">✓ Descuento fiel −{o.discount_pct}% aplicado</div>
          )}

          <div class="ordcard__view">
            <div class="muted ordcard__cli">{o.client_name} · {o.client_contact}</div>
            {o.delivery_address && <div class="muted ordcard__cli">📍 {o.delivery_address}</div>}
            {o.delivery_date && <div class="muted ordcard__cli">🗓️ Entrega: {o.delivery_date}</div>}
            {o.notes && <div class="muted ordcard__cli">📝 {o.notes}</div>}
          </div>

          <div class="ordcard__edit">
            <div class="grid2">
              <div><label>Cliente</label><input class="of-name" value={o.client_name} /></div>
              <div><label>Contacto</label><input class="of-contact" value={o.client_contact} /></div>
            </div>
            <label>Dirección de entrega</label>
            <input class="of-addr" value={o.delivery_address || ''} />
            <div class="grid2">
              <div><label>Día de entrega</label><input class="of-date" type="date" value={o.delivery_date || ''} /></div>
              <div><label>Notas</label><input class="of-notes" value={o.notes || ''} /></div>
            </div>
          </div>

          <ul class="ordcard__items">
            {(itemsByOrder[o.id] || []).map((it: any) => (
              <li class="oi-row" data-item={it.id} data-price={it.unit_price}>
                <span class="oi-name">{it.name} <small class="muted">{it.pack_label}</small></span>
                <span class="oi-qty">
                  <span class="qty-view">{it.qty}</span>
                  <input class="qty-edit" type="number" min="0" value={it.qty} aria-label={`Cantidad de ${it.name}`} />
                  <span class="muted"> × {money(it.unit_price)}</span>
                </span>
                <span class="oi-line" data-line>{money(it.line_total)}</span>
              </li>
            ))}
            {(itemsByOrder[o.id] || []).length === 0 && <li class="muted">Sin detalle de ítems.</li>}
          </ul>

          {o.status === 'confirmado' && (
            <div class="ordcard__arch">
              {o.archived && <span class="arch arch--ok">✓ Remitos</span>}
              {o.archived && <a class="arch-link" href={o.remito_cliente_url} target="_blank" rel="noopener">📄 Cliente</a>}
              {o.archived && <a class="arch-link" href={o.remito_interno_url} target="_blank" rel="noopener">📄 Interno</a>}
              {!o.archived && <span class="arch arch--err">⚠️ Sin archivar{o.archive_error ? `: ${o.archive_error}` : ''}</span>}
              {!o.archived && <button class="btn btn--ghost retry-arch" type="button" data-id={o.id}>Reintentar</button>}
            </div>
          )}

          <div class="ordcard__actions">
            {o.status === 'pendiente' && <button class="btn btn--ghost edit-ord" type="button">✏️ Editar pedido</button>}
            {o.status === 'pendiente' && <button class="btn save-ord" type="button">Guardar</button>}
            {o.status === 'pendiente' && <button class="btn btn--ghost cancel-ord" type="button">Cancelar</button>}
            {o.status === 'pendiente' && <button class="btn confirm" data-id={o.id}>Confirmar ✓</button>}
            <button class="btn btn--danger del-ord" type="button" data-num={o.order_number || `#${o.id}`}>Borrar</button>
          </div>
        </div>
      ))}
    </section>

    <!-- PRODUCTOS -->
    <section class="panel" data-panel="productos" hidden>
      <div class="card">
        <div class="table-scroll">
        <table>
          <thead><tr><th>Producto</th><th>Rubro</th><th>Pack</th><th>Precio</th><th>Stock</th><th></th></tr></thead>
          <tbody>
            {productRows.map((p: any) => (
              <tr>
                <td data-label="Producto"><span class="td-v">{p.name}{!p.active && <span class="muted"> (oculto)</span>}</span></td>
                <td data-label="Rubro" class="muted"><span class="td-v">{p.category || '—'}</span></td>
                <td data-label="Pack"><span class="td-v">{p.pack_label}</span></td>
                <td data-label="Precio"><span class="td-v">{money(p.price)}</span></td>
                <td data-label="Stock"><span class="td-v">
                  {p.stock}{' '}
                  {p.isOut && <span class="badge badge--out">sin stock</span>}
                  {p.isLow && <span class="badge badge--low">poco stock</span>}
                </span></td>
                <td class="prod-actions">
                  <button class="btn btn--ghost editp" data-p={JSON.stringify(p)}>Editar</button>
                  <button class="btn btn--danger del-prod" type="button" data-id={p.id} data-name={p.name}>Borrar</button>
                </td>
              </tr>
            ))}
            {productRows.length === 0 && <tr><td colspan="6" class="muted">Sin productos. Cargá el primero en “＋ Nuevo producto”.</td></tr>}
          </tbody>
        </table>
        </div>
      </div>
    </section>

    <!-- NUEVO / EDITAR -->
    <section class="panel" data-panel="nuevo" hidden>
      <div class="editor">
        <div class="card form-card">
          <h2 id="formTitle" style="margin-top:0">Nuevo producto</h2>
          <form id="pform">
            <input type="hidden" name="id" />

            <label for="pf-name">Nombre</label>
            <input id="pf-name" name="name" required autocomplete="off" />

            <label for="pf-desc">Descripción</label>
            <textarea id="pf-desc" name="description" rows="2" placeholder="Ej: Base de vainilla, frutos rojos frescos." autocomplete="off"></textarea>

            <label for="pf-cat">Rubro</label>
            <select id="pf-cat" name="category">
              <option value="">— Elegí un rubro —</option>
              {catNames.map((c) => <option value={c}>{c}</option>)}
            </select>
            <p class="hint">¿Falta un rubro? Crealo en la pestaña <b>Rubros</b>.</p>

            <label>Foto del producto</label>
            <div class="filepick">
              <label class="filebtn" id="pfilebtn" for="pfile">📷 Subir foto</label>
              <input type="file" id="pfile" accept="image/*" />
            </div>
            <input name="image_url" placeholder="…o pegá una URL de imagen" style="margin-top:8px" />
            <p class="hint">Subí un archivo (recomendado) o pegá una URL. Se ajusta y comprime automáticamente.</p>

            <div class="grid2">
              <div><label for="pf-pack">Pack</label><input id="pf-pack" name="pack_label" placeholder="x6, x12, por kg" /></div>
              <div><label for="pf-price">Precio mayorista</label><input id="pf-price" name="price" type="number" step="0.01" min="0" required /></div>
              <div><label for="pf-stock">Stock (packs)</label><input id="pf-stock" name="stock" type="number" min="0" required /></div>
              <div><label for="pf-low">Avisar si baja de</label><input id="pf-low" name="low_stock_threshold" type="number" min="0" value="5" /></div>
            </div>

            <label class="check"><input type="checkbox" name="active" checked /> Visible en el catálogo</label>

            <div class="form-actions">
              <button class="btn" type="submit">Guardar producto</button>
              <button class="btn btn--ghost" type="button" id="pclear">Limpiar</button>
            </div>
            <p id="pmsg" class="muted"></p>
          </form>
        </div>

        <aside class="preview-pane" aria-hidden="true">
          <p class="preview-pane__label">👁 Vista previa</p>
          <p class="preview-section">Así lo verá el cliente · Sección: <b id="pv-cat">—</b></p>
          <div class="preview-stage">
            <div class="item is-preview" id="pv-item">
              <div class="thumb-box">
                <span class="thumb-ph" id="pv-initial">?</span>
                <img class="thumb-img" id="pv-img" hidden alt="" />
              </div>
              <div class="item__info">
                <p class="item__name" id="pv-name">Nombre del producto</p>
                <p class="item__desc" id="pv-desc" hidden></p>
                <div class="item__meta"><span class="pack" id="pv-pack" hidden></span></div>
              </div>
              <div class="item__buy">
                <span class="price" id="pv-price">$0</span>
                <div id="pv-buy"></div>
              </div>
            </div>
            <p class="pv-hidden-note" id="pv-hidden" hidden>🔒 Oculto — no aparece en el catálogo</p>
          </div>
        </aside>
      </div>
    </section>

    <!-- RUBROS -->
    <section class="panel" data-panel="rubros" hidden>
      <div class="card form-card">
        <h2 style="margin-top:0">Rubros (categorías)</h2>
        <p class="hint">Son las secciones del catálogo. Los productos se agrupan por rubro.</p>
        <ul class="rubro-list" id="rubroList">
          {categories.map((c: any) => (
            <li><span>{c.name}</span><button class="btn btn--ghost del-cat" type="button" data-id={c.id} data-name={c.name}>Eliminar</button></li>
          ))}
          {categories.length === 0 && <li class="muted">Sin rubros todavía.</li>}
        </ul>
        <form id="catform" style="margin-top:16px">
          <label for="cat-name">Nuevo rubro</label>
          <input id="cat-name" name="catname" placeholder="Ej: Sin TACC" autocomplete="off" required />
          <div class="form-actions"><button class="btn" type="submit">Agregar rubro</button></div>
          <p id="catmsg" class="muted"></p>
        </form>
      </div>
    </section>
  </div>

  <script>
    // ---- tabs ----
    const showTab = (name) => {
      document.querySelectorAll('.tab').forEach((t) => t.classList.toggle('is-active', t.dataset.tab === name));
      document.querySelectorAll('[data-panel]').forEach((p) => (p.hidden = p.dataset.panel !== name));
    };
    document.querySelectorAll('.tab').forEach((t) =>
      t.addEventListener('click', () => {
        if (t.dataset.tab === 'nuevo') resetForm();
        showTab(t.dataset.tab);
        history.replaceState(null, '', '#' + t.dataset.tab);
      })
    );

    // ---- confirmar pedido ----
    document.querySelectorAll('.confirm').forEach((b) =>
      b.addEventListener('click', async () => {
        b.textContent = '…';
        const r = await fetch('/api/admin/confirm', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: b.dataset.id }),
        });
        if (r.ok) location.reload();
        else b.textContent = 'Error';
      })
    );

    // ---- reintentar archivado de remitos ----
    document.querySelectorAll('.retry-arch').forEach((b) =>
      b.addEventListener('click', async () => {
        b.textContent = 'Archivando…'; b.disabled = true;
        const r = await fetch('/api/admin/archive', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: b.dataset.id }),
        });
        if (r.ok) location.reload();
        else { b.textContent = 'Reintentar'; b.disabled = false; alert('No se pudo archivar. Probá de nuevo.'); }
      })
    );

    // ---- form producto + vista previa en vivo ----
    const form = document.getElementById('pform');
    const F = (n) => form.elements.namedItem(n); // robusto: evita el shadowing de form.name / form.id
    const fileInput = document.getElementById('pfile');
    const fileBtn = document.getElementById('pfilebtn');
    const msg = document.getElementById('pmsg');
    const money = (n) => '$' + Number(n || 0).toLocaleString('es-AR');

    // Redimensiona/comprime la imagen en el navegador antes de subir (evita el límite de 4,5MB
    // de Vercel y hace el catálogo más liviano). Si algo falla, devuelve el archivo original.
    async function resizeImage(file, maxDim = 1400, quality = 0.85) {
      try {
        const bitmap = await createImageBitmap(file);
        let w = bitmap.width, h = bitmap.height;
        if (Math.max(w, h) > maxDim) { const s = maxDim / Math.max(w, h); w = Math.round(w * s); h = Math.round(h * s); }
        const canvas = document.createElement('canvas');
        canvas.width = w; canvas.height = h;
        canvas.getContext('2d').drawImage(bitmap, 0, 0, w, h);
        if (bitmap.close) bitmap.close();
        const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', quality));
        if (!blob) return file;
        const base = (file.name || 'foto').replace(/\.[^.]+$/, '') || 'foto';
        return new File([blob], base + '.jpg', { type: 'image/jpeg' });
      } catch { return file; }
    }

    function updatePreview() {
      const name = F('name').value.trim();
      const desc = F('description') ? F('description').value.trim() : '';
      const cat = F('category').value.trim();
      const pack = F('pack_label').value.trim();
      const stock = Number(F('stock').value) || 0;
      const active = F('active') ? F('active').checked : true;
      const file = fileInput && fileInput.files && fileInput.files[0];
      const imgSrc = file ? URL.createObjectURL(file) : F('image_url').value.trim();

      const set = (id, txt) => { const e = document.getElementById(id); if (e) e.textContent = txt; };
      set('pv-name', name || 'Nombre del producto');
      set('pv-cat', cat || '—');
      set('pv-price', money(F('price').value));
      set('pv-initial', (name.charAt(0) || '?').toUpperCase());
      const dEl = document.getElementById('pv-desc'); dEl.textContent = desc; dEl.hidden = !desc;
      const pEl = document.getElementById('pv-pack'); pEl.textContent = pack; pEl.hidden = !pack;
      const img = document.getElementById('pv-img');
      if (imgSrc) { img.src = imgSrc; img.hidden = false; } else { img.hidden = true; img.removeAttribute('src'); }
      document.getElementById('pv-buy').innerHTML = stock > 0
        ? '<div class="stepper"><span class="step-btn">−</span><span class="qty">0</span><span class="step-btn">+</span></div>'
        : '<span class="badge-out">Sin stock</span>';
      document.getElementById('pv-item').classList.toggle('is-hidden', !active);
      document.getElementById('pv-hidden').hidden = active;
    }

    function fillForm(p) {
      // si el rubro del producto no está en el dropdown (fue borrado), lo agregamos como opción
      const catSel = F('category');
      if (catSel && p.category && !Array.from(catSel.options).some((o) => o.value === p.category)) {
        catSel.add(new Option(p.category, p.category));
      }
      ['id', 'name', 'description', 'category', 'image_url', 'pack_label', 'price', 'stock', 'low_stock_threshold'].forEach((k) => {
        const el = F(k); if (el) el.value = p[k] ?? '';
      });
      if (F('active')) F('active').checked = p.active !== false;
      if (fileInput) fileInput.value = '';
      if (fileBtn) fileBtn.textContent = '📷 Subir foto';
      updatePreview();
    }
    function resetForm() {
      form.reset();
      document.getElementById('formTitle').textContent = 'Nuevo producto';
      if (fileInput) fileInput.value = '';
      if (fileBtn) fileBtn.textContent = '📷 Subir foto';
      msg.textContent = '';
      updatePreview();
    }

    document.querySelectorAll('.editp').forEach((b) =>
      b.addEventListener('click', () => {
        fillForm(JSON.parse(b.dataset.p));
        document.getElementById('formTitle').textContent = 'Editar producto';
        showTab('nuevo');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      })
    );

    document.querySelectorAll('.del-prod').forEach((b) =>
      b.addEventListener('click', async () => {
        if (!confirm('¿Borrar el producto "' + b.dataset.name + '"? No se puede deshacer.')) return;
        b.textContent = '…';
        const r = await fetch('/api/admin/product', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete', id: b.dataset.id }),
        });
        if (r.ok) location.reload();
        else b.textContent = 'Error';
      })
    );

    fileInput?.addEventListener('change', () => {
      const f = fileInput.files && fileInput.files[0];
      if (fileBtn) fileBtn.textContent = f ? '✓ Foto lista' : '📷 Subir foto';
      updatePreview();
    });
    form.addEventListener('input', updatePreview);
    document.getElementById('pclear').addEventListener('click', resetForm);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      msg.className = 'muted';
      let image_url = F('image_url').value.trim();
      const file = fileInput && fileInput.files && fileInput.files[0];

      // 1) subir la imagen si eligió un archivo: se comprime y se manda como BASE64 en JSON
      //    (NO multipart — Vercel bloquea el multipart con 403 vía WAF).
      if (file) {
        msg.textContent = 'Procesando imagen…';
        const toUpload = await resizeImage(file);
        const dataUrl = await new Promise((res) => {
          const rd = new FileReader(); rd.onload = () => res(rd.result); rd.onerror = () => res(''); rd.readAsDataURL(toUpload);
        });
        if (!dataUrl) { msg.textContent = 'No se pudo leer la imagen.'; return; }
        msg.textContent = 'Subiendo imagen…';
        let up, uo;
        try {
          up = await fetch('/api/admin/upload', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ contentType: toUpload.type, data: dataUrl }),
          });
          uo = await up.json().catch(() => ({}));
        } catch { msg.textContent = 'No se pudo conectar para subir la imagen.'; return; }
        if (up.ok && uo.url) image_url = uo.url;
        else { msg.textContent = (uo && uo.error) || ('No se pudo subir la imagen (código ' + (up ? up.status : '?') + ').'); return; }
      }

      // 2) guardar el producto
      msg.textContent = 'Guardando…';
      const payload = {
        id: F('id').value,
        name: F('name').value.trim(),
        description: F('description').value.trim(),
        category: F('category').value.trim(),
        image_url,
        pack_label: F('pack_label').value.trim(),
        price: F('price').value,
        stock: F('stock').value,
        low_stock_threshold: F('low_stock_threshold').value,
        active: F('active') ? F('active').checked : true,
      };
      const r = await fetch('/api/admin/product', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
      });
      if (r.ok) {
        const editing = !!F('id').value;
        msg.className = 'ok-msg';
        msg.textContent = editing ? '✓ Producto actualizado' : '✓ ¡Producto agregado!';
        setTimeout(() => { location.hash = 'productos'; location.reload(); }, 950);
      } else {
        const o = await r.json().catch(() => ({}));
        msg.textContent = (o && o.error) || 'Error al guardar.';
      }
    });

    // ---- editar un pedido (datos + cantidades) ----
    document.querySelectorAll('.ordcard').forEach((card) => {
      const totalEl = card.querySelector('[data-total]');
      const rows = [...card.querySelectorAll('.oi-row')];
      const val = (sel) => { const e = card.querySelector(sel); return e ? e.value : undefined; };
      const discPct = () => (card.querySelector('.disc-toggle')?.checked ? 10 : 0);
      const recompute = () => {
        let subtotal = 0;
        rows.forEach((row) => {
          const price = Number(row.dataset.price) || 0;
          const qty = Math.max(0, parseInt(row.querySelector('.qty-edit').value) || 0);
          const line = price * qty;
          subtotal += line;
          row.querySelector('[data-line]').textContent = money(line);
        });
        if (totalEl) totalEl.textContent = money(Math.round(subtotal * (1 - discPct() / 100)));
      };
      // Toggle de descuento fiel: guarda al instante y recarga (recalcula total + remito).
      card.querySelector('.disc-toggle')?.addEventListener('change', async (e) => {
        const r = await fetch('/api/admin/order', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ id: card.dataset.id, discount_pct: e.target.checked ? 10 : 0 }),
        });
        if (r.ok) location.reload();
        else { e.target.checked = !e.target.checked; alert('No se pudo aplicar el descuento.'); }
      });
      card.querySelector('.edit-ord')?.addEventListener('click', () => card.classList.add('editing'));
      card.querySelector('.cancel-ord')?.addEventListener('click', () => {
        card.querySelectorAll('input').forEach((i) => (i.value = i.defaultValue));
        card.classList.remove('editing');
        recompute();
      });
      rows.forEach((row) => row.querySelector('.qty-edit')?.addEventListener('input', recompute));
      card.querySelector('.save-ord')?.addEventListener('click', async () => {
        const btn = card.querySelector('.save-ord');
        const items = rows.map((row) => ({ id: row.dataset.item, qty: Math.max(0, parseInt(row.querySelector('.qty-edit').value) || 0) }));
        btn.textContent = 'Guardando…';
        const r = await fetch('/api/admin/order', {
          method: 'POST', headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            id: card.dataset.id, items,
            client_name: val('.of-name'), client_contact: val('.of-contact'),
            delivery_address: val('.of-addr'), delivery_date: val('.of-date'), notes: val('.of-notes'),
            discount_pct: discPct(),
          }),
        });
        if (r.ok) location.reload();
        else btn.textContent = 'Error';
      });

      card.querySelector('.del-ord')?.addEventListener('click', async () => {
        const b = card.querySelector('.del-ord');
        if (!confirm('¿Borrar el pedido ' + (b.dataset.num || '') + '? No se puede deshacer.')) return;
        b.textContent = '…';
        const r = await fetch('/api/admin/order', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete', id: card.dataset.id }),
        });
        if (r.ok) location.reload();
        else b.textContent = 'Error';
      });
    });

    // ---- rubros / categorías ----
    const catform = document.getElementById('catform');
    if (catform) {
      const catmsg = document.getElementById('catmsg');
      catform.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = catform.elements.namedItem('catname').value.trim();
        if (!name) return;
        catmsg.className = 'muted';
        catmsg.textContent = 'Agregando…';
        const r = await fetch('/api/admin/category', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ name }),
        });
        if (r.ok) location.reload();
        else { const o = await r.json().catch(() => ({})); catmsg.textContent = (o && o.error) || 'No se pudo agregar.'; }
      });
    }
    document.querySelectorAll('.del-cat').forEach((b) =>
      b.addEventListener('click', async () => {
        if (!confirm('¿Eliminar el rubro "' + b.dataset.name + '"? Los productos que lo usan no se borran.')) return;
        b.textContent = '…';
        const r = await fetch('/api/admin/category', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ action: 'delete', id: b.dataset.id }),
        });
        if (r.ok) location.reload();
        else b.textContent = 'Error';
      })
    );

    // deep-link por hash (#pedidos / #productos / #nuevo / #rubros)
    const initTab = (location.hash || '').slice(1);
    if (['pedidos', 'productos', 'nuevo', 'rubros'].includes(initTab)) { if (initTab === 'nuevo') resetForm(); showTab(initTab); }

    updatePreview();
  </script>
</Base>
