---
export const prerender = false;
import Base from '../layouts/Base.astro';
import { isTeiaAdmin, authChallenge } from '../lib/auth';
import { sbSelect, supaConfigured } from '../lib/supabase';
import { DEMO_PRODUCTS, DEMO_ORDERS } from '../lib/demo';

// Gate: in real mode (Supabase configured) require the panel password. In demo mode it's open.
const configured = supaConfigured();
if (configured && !isTeiaAdmin(Astro.request)) {
  return authChallenge();
}

const products = configured ? await sbSelect('teia_products?order=sort_order.asc,name.asc&select=*') : DEMO_PRODUCTS;
const orders = configured ? await sbSelect('teia_orders?order=created_at.desc&select=*&limit=50') : DEMO_ORDERS;
const money = (n: any) => '$' + Number(n || 0).toLocaleString('es-AR');

// Stock flags precomputed (Astro can't mix `<=` with adjacent JSX).
const productRows = (products as any[]).map((p) => ({
  ...p,
  isOut: Number(p.stock) <= 0,
  isLow: Number(p.stock) > 0 && Number(p.stock) <= Number(p.low_stock_threshold),
}));

// Rubros for the datalist: the standard set + whatever already exists.
const rubros = [...new Set(['Tortas', 'Postres', 'Salados', 'Panadería', ...(products as any[]).map((p) => p.category).filter(Boolean)])];

const DRIVE_URL = '';
const SHEET_URL = '';
---
<Base title="Administradora — Teia Bakery">
  <div class="container">
    <div class="brand">Teia Bakery · Administradora</div>
    <h1 style="margin-bottom:6px">Panel</h1>

    {!configured && <p class="card" style="margin-bottom:12px">🧪 <b>Modo demo</b> — datos de ejemplo. Conectá Supabase + la clave para el panel real.</p>}

    <p class="links-row">
      <a class="btn btn--ghost" href={DRIVE_URL || '#'} target="_blank" rel="noopener">📁 Drive</a>
      <a class="btn btn--ghost" href={SHEET_URL || '#'} target="_blank" rel="noopener">📊 Google Sheet</a>
      <a class="btn btn--ghost" href="mailto:hello@kyndredai.com">🛟 Soporte</a>
    </p>

    <div class="tabs" role="tablist">
      <button class="tab is-active" data-tab="pedidos" type="button">Pedidos</button>
      <button class="tab" data-tab="productos" type="button">Productos</button>
      <button class="tab" data-tab="nuevo" type="button">＋ Nuevo producto</button>
    </div>

    <!-- PEDIDOS -->
    <section class="panel" data-panel="pedidos">
      <div class="card">
        <table>
          <thead><tr><th>N°</th><th>Cliente</th><th>Entrega</th><th>Total</th><th>Estado</th><th></th></tr></thead>
          <tbody>
            {orders.map((o: any) => (
              <tr>
                <td>{o.order_number || '—'}</td>
                <td>{o.client_name}<br /><small class="muted">{o.client_contact}</small></td>
                <td>{o.delivery_date || '—'}</td>
                <td>{money(o.total)}</td>
                <td>{o.status}</td>
                <td>{o.status === 'pendiente' && <button class="btn confirm" data-id={o.id}>Confirmar ✓</button>}</td>
              </tr>
            ))}
            {orders.length === 0 && <tr><td colspan="6" class="muted">Sin pedidos todavía.</td></tr>}
          </tbody>
        </table>
      </div>
    </section>

    <!-- PRODUCTOS -->
    <section class="panel" data-panel="productos" hidden>
      <div class="card">
        <table>
          <thead><tr><th>Producto</th><th>Rubro</th><th>Pack</th><th>Precio</th><th>Stock</th><th></th></tr></thead>
          <tbody>
            {productRows.map((p: any) => (
              <tr>
                <td>{p.name}{!p.active && <span class="muted"> (oculto)</span>}</td>
                <td class="muted">{p.category || '—'}</td>
                <td>{p.pack_label}</td>
                <td>{money(p.price)}</td>
                <td>
                  {p.stock}{' '}
                  {p.isOut && <span class="badge badge--out">sin stock</span>}
                  {p.isLow && <span class="badge badge--low">poco stock</span>}
                </td>
                <td><button class="btn btn--ghost editp" data-p={JSON.stringify(p)}>Editar</button></td>
              </tr>
            ))}
            {productRows.length === 0 && <tr><td colspan="6" class="muted">Sin productos. Cargá el primero en “＋ Nuevo producto”.</td></tr>}
          </tbody>
        </table>
      </div>
    </section>

    <!-- NUEVO / EDITAR -->
    <section class="panel" data-panel="nuevo" hidden>
      <div class="editor">
        <div class="card form-card">
          <h2 id="formTitle" style="margin-top:0">Nuevo producto</h2>
          <form id="pform">
            <input type="hidden" name="id" />

            <label for="pf-name">Nombre</label>
            <input id="pf-name" name="name" required autocomplete="off" />

            <label for="pf-desc">Descripción</label>
            <textarea id="pf-desc" name="description" rows="2" placeholder="Ej: Base de vainilla, frutos rojos frescos." autocomplete="off"></textarea>

            <label for="pf-cat">Rubro</label>
            <input id="pf-cat" name="category" list="rubros-list" placeholder="Tortas, Postres, Salados…" autocomplete="off" />
            <datalist id="rubros-list">{rubros.map((r) => <option value={r} />)}</datalist>

            <label>Foto del producto</label>
            <div class="filepick">
              <label class="filebtn" id="pfilebtn" for="pfile">📷 Subir foto</label>
              <input type="file" id="pfile" accept="image/*" />
            </div>
            <input name="image_url" placeholder="…o pegá una URL de imagen" style="margin-top:8px" />
            <p class="hint">Subí un archivo (recomendado) o pegá una URL. Máx 5&nbsp;MB.</p>

            <div class="grid2">
              <div><label for="pf-pack">Pack</label><input id="pf-pack" name="pack_label" placeholder="x6, x12, por kg" /></div>
              <div><label for="pf-price">Precio mayorista</label><input id="pf-price" name="price" type="number" step="0.01" min="0" required /></div>
              <div><label for="pf-stock">Stock (packs)</label><input id="pf-stock" name="stock" type="number" min="0" required /></div>
              <div><label for="pf-low">Avisar si baja de</label><input id="pf-low" name="low_stock_threshold" type="number" min="0" value="5" /></div>
            </div>

            <label class="check"><input type="checkbox" name="active" checked /> Visible en el catálogo</label>

            <div class="form-actions">
              <button class="btn" type="submit">Guardar producto</button>
              <button class="btn btn--ghost" type="button" id="pclear">Limpiar</button>
            </div>
            <p id="pmsg" class="muted"></p>
          </form>
        </div>

        <aside class="preview-pane" aria-hidden="true">
          <p class="preview-pane__label">👁 Vista previa</p>
          <p class="preview-section">Así lo verá el cliente · Sección: <b id="pv-cat">—</b></p>
          <div class="preview-stage">
            <div class="item is-preview" id="pv-item">
              <div class="thumb-box">
                <span class="thumb-ph" id="pv-initial">?</span>
                <img class="thumb-img" id="pv-img" hidden alt="" />
              </div>
              <div class="item__info">
                <p class="item__name" id="pv-name">Nombre del producto</p>
                <p class="item__desc" id="pv-desc" hidden></p>
                <div class="item__meta"><span class="pack" id="pv-pack" hidden></span></div>
              </div>
              <div class="item__buy">
                <span class="price" id="pv-price">$0</span>
                <div id="pv-buy"></div>
              </div>
            </div>
            <p class="pv-hidden-note" id="pv-hidden" hidden>🔒 Oculto — no aparece en el catálogo</p>
          </div>
        </aside>
      </div>
    </section>
  </div>

  <script>
    // ---- tabs ----
    const showTab = (name) => {
      document.querySelectorAll('.tab').forEach((t) => t.classList.toggle('is-active', t.dataset.tab === name));
      document.querySelectorAll('[data-panel]').forEach((p) => (p.hidden = p.dataset.panel !== name));
    };
    document.querySelectorAll('.tab').forEach((t) =>
      t.addEventListener('click', () => {
        if (t.dataset.tab === 'nuevo') resetForm();
        showTab(t.dataset.tab);
        history.replaceState(null, '', '#' + t.dataset.tab);
      })
    );

    // ---- confirmar pedido ----
    document.querySelectorAll('.confirm').forEach((b) =>
      b.addEventListener('click', async () => {
        b.textContent = '…';
        const r = await fetch('/api/admin/confirm', {
          method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ id: b.dataset.id }),
        });
        if (r.ok) location.reload();
        else b.textContent = 'Error';
      })
    );

    // ---- form producto + vista previa en vivo ----
    const form = document.getElementById('pform');
    const F = (n) => form.elements.namedItem(n); // robusto: evita el shadowing de form.name / form.id
    const fileInput = document.getElementById('pfile');
    const fileBtn = document.getElementById('pfilebtn');
    const msg = document.getElementById('pmsg');
    const money = (n) => '$' + Number(n || 0).toLocaleString('es-AR');

    function updatePreview() {
      const name = F('name').value.trim();
      const desc = F('description') ? F('description').value.trim() : '';
      const cat = F('category').value.trim();
      const pack = F('pack_label').value.trim();
      const stock = Number(F('stock').value) || 0;
      const active = F('active') ? F('active').checked : true;
      const file = fileInput && fileInput.files && fileInput.files[0];
      const imgSrc = file ? URL.createObjectURL(file) : F('image_url').value.trim();

      const set = (id, txt) => { const e = document.getElementById(id); if (e) e.textContent = txt; };
      set('pv-name', name || 'Nombre del producto');
      set('pv-cat', cat || '—');
      set('pv-price', money(F('price').value));
      set('pv-initial', (name.charAt(0) || '?').toUpperCase());
      const dEl = document.getElementById('pv-desc'); dEl.textContent = desc; dEl.hidden = !desc;
      const pEl = document.getElementById('pv-pack'); pEl.textContent = pack; pEl.hidden = !pack;
      const img = document.getElementById('pv-img');
      if (imgSrc) { img.src = imgSrc; img.hidden = false; } else { img.hidden = true; img.removeAttribute('src'); }
      document.getElementById('pv-buy').innerHTML = stock > 0
        ? '<div class="stepper"><span class="step-btn">−</span><span class="qty">0</span><span class="step-btn">+</span></div>'
        : '<span class="badge-out">Sin stock</span>';
      document.getElementById('pv-item').classList.toggle('is-hidden', !active);
      document.getElementById('pv-hidden').hidden = active;
    }

    function fillForm(p) {
      ['id', 'name', 'description', 'category', 'image_url', 'pack_label', 'price', 'stock', 'low_stock_threshold'].forEach((k) => {
        const el = F(k); if (el) el.value = p[k] ?? '';
      });
      if (F('active')) F('active').checked = p.active !== false;
      if (fileInput) fileInput.value = '';
      if (fileBtn) fileBtn.textContent = '📷 Subir foto';
      updatePreview();
    }
    function resetForm() {
      form.reset();
      document.getElementById('formTitle').textContent = 'Nuevo producto';
      if (fileInput) fileInput.value = '';
      if (fileBtn) fileBtn.textContent = '📷 Subir foto';
      msg.textContent = '';
      updatePreview();
    }

    document.querySelectorAll('.editp').forEach((b) =>
      b.addEventListener('click', () => {
        fillForm(JSON.parse(b.dataset.p));
        document.getElementById('formTitle').textContent = 'Editar producto';
        showTab('nuevo');
        window.scrollTo({ top: 0, behavior: 'smooth' });
      })
    );

    fileInput?.addEventListener('change', () => {
      const f = fileInput.files && fileInput.files[0];
      if (fileBtn) fileBtn.textContent = f ? '✓ Foto lista' : '📷 Subir foto';
      updatePreview();
    });
    form.addEventListener('input', updatePreview);
    document.getElementById('pclear').addEventListener('click', resetForm);

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      let image_url = F('image_url').value.trim();
      const file = fileInput && fileInput.files && fileInput.files[0];

      // 1) subir la imagen si eligió un archivo
      if (file) {
        msg.textContent = 'Subiendo imagen…';
        const fd = new FormData();
        fd.append('file', file);
        const up = await fetch('/api/admin/upload', { method: 'POST', body: fd });
        const uo = await up.json().catch(() => ({}));
        if (up.ok && uo.url) image_url = uo.url;
        else { msg.textContent = (uo && uo.error) || 'No se pudo subir la imagen.'; return; }
      }

      // 2) guardar el producto
      msg.textContent = 'Guardando…';
      const payload = {
        id: F('id').value,
        name: F('name').value.trim(),
        description: F('description').value.trim(),
        category: F('category').value.trim(),
        image_url,
        pack_label: F('pack_label').value.trim(),
        price: F('price').value,
        stock: F('stock').value,
        low_stock_threshold: F('low_stock_threshold').value,
        active: F('active') ? F('active').checked : true,
      };
      const r = await fetch('/api/admin/product', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload),
      });
      if (r.ok) location.reload();
      else { const o = await r.json().catch(() => ({})); msg.textContent = (o && o.error) || 'Error al guardar.'; }
    });

    // deep-link por hash (#pedidos / #productos / #nuevo)
    const initTab = (location.hash || '').slice(1);
    if (['pedidos', 'productos', 'nuevo'].includes(initTab)) { if (initTab === 'nuevo') resetForm(); showTab(initTab); }

    updatePreview();
  </script>
</Base>
