---
import '../styles/global.css';
interface Props {
  title?: string;
}
const { title = 'Teia Bakery — Mayorista' } = Astro.props;
---
<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="robots" content="noindex" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400..600&family=Inter:wght@400..700&display=swap" rel="stylesheet" />
  </head>
  <body>
    <slot />
    <script>
      import Lenis from 'lenis';
      // Smooth scroll (igual que kyndredai.com). Respeta prefers-reduced-motion y no toca el
      // touch (Lenis deja el scroll táctil nativo), así que el sheet/modal en mobile van fluidos.
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (!reduce) {
        const lenis = new Lenis({ duration: 1.05, smoothWheel: true, wheelMultiplier: 1 });
        const raf = (t) => { lenis.raf(t); requestAnimationFrame(raf); };
        requestAnimationFrame(raf);
        // anchors internos (chips de rubro) → scroll suave con offset para el nav sticky
        document.querySelectorAll('a[href^="#"]').forEach((a) => {
          a.addEventListener('click', (e) => {
            const href = a.getAttribute('href');
            if (!href || href === '#') return;
            const el = document.querySelector(href);
            if (el) { e.preventDefault(); lenis.scrollTo(el, { offset: -76 }); }
          });
        });
      }
    </script>
  </body>
</html>
