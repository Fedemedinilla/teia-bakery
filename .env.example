# --- Supabase (proyecto de Teia) ---------------------------------------------
# La service_role key es SECRETA y bypassa RLS: va SOLO en las env vars de Vercel,
# NUNCA en el repo ni en el cliente.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Panel /administradora ---------------------------------------------------
# Clave que usa Teia para entrar al panel (la elige ella).
TEIA_ADMIN_PASSWORD=

# --- Tienda -------------------------------------------------------------------
# Pedido mínimo en ARS (default 40000 si está vacío).
TEIA_MIN_ORDER=

# WhatsApp de Teia (solo dígitos, con código de país). Se usa en la puerta, para que el
# CUIT no habilitado pueda pedir el alta, y en el mensaje de acceso del panel.
TEIA_WHATSAPP=5491176239937

# URL pública de la app (para el mensaje de acceso que se manda por WhatsApp).
TEIA_APP_URL=

# --- 2º factor de entrada: CUIT + código (APAGADO por defecto) -----------------
# El CUIT de un comercio es un dato PÚBLICO (facturas, constancia de AFIP), así que por sí
# solo no protege los precios. Con esto en 'true', además del CUIT se pide el código que
# Teia le pasó al cliente. Los códigos ya se generan y administran desde el panel aunque
# esto esté apagado, así que encenderlo es cambiar esta variable y redeployar.
# ⚠️ Al encenderlo, una cuenta SIN código cargado no puede entrar (falla cerrado).
TEIA_REQUIRE_CODE=

# --- Barrido nocturno (/api/cron/sweep) ---------------------------------------
# Opcional pero recomendado: si está seteada, Vercel manda `Authorization: Bearer <secret>`
# en cada corrida del cron y el endpoint la exige. Cualquier string largo al azar sirve.
CRON_SECRET=

# --- Espejo Google Sheet + Drive (OAuth de la cuenta de la clienta) -------------
# OAuth Client de Google Cloud (APIs: Drive + Sheets; scope drive.file; redirect URI:
# https://<dominio>/api/admin/google/callback). El REFRESH_TOKEN sale del botón
# "Conectar Google" del panel — al hacer el handoff se re-consiente con la cuenta de la
# clienta y solo se reemplaza ese token: la carpeta y la planilla se auto-crean en su Drive.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=
