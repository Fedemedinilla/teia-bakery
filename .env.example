# --- Supabase (proyecto de Teia) ---------------------------------------------
# La service_role key es SECRETA y bypassa RLS: va SOLO en las env vars de Vercel,
# NUNCA en el repo ni en el cliente.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Panel /administradora ---------------------------------------------------
# Clave que usa Teia para entrar al panel (la elige ella).
TEIA_ADMIN_PASSWORD=

# --- Archivador n8n (opcional) -----------------------------------------------
# Webhook que se dispara al Confirmar un pedido (genera remitos, Drive, Sheet, email).
# Si está vacío, el confirmar igual descuenta stock; solo no avisa a n8n.
N8N_WEBHOOK_URL=
